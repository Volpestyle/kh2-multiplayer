# Minimal runtime scaffold config

# Runtime mode: campaign_coop (default) or public_realm
runtime_mode = campaign_coop

# Slot ownership: 0 = Player, 1 = Friend1, 2 = Friend2
# Only used in CampaignCoop mode.
client_role = 0

# Enable local camera override and allow the F8 panic toggle.
camera_override = true
panic_hotkey = true

# Optional local diagnostics.
log_owned_actor_state = false
tick_ms = 16

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

# Enable networking (connect to a SessionHost server).
# Default: false (offline mode — local camera + diagnostics only).
# Also settable via --network / --no-network CLI flags.
networking = false

# SessionHost server address and port.
server_host = 127.0.0.1
server_port = 7946

# Unique identifier for this peer. Each connected client must use a
# different peer_id.
peer_id = player-1

# Game build string sent in the version handshake.
# Must match the server's expected build for the connection to be accepted.
game_build = 1.0.0.10-steam-global

# Mod content hash sent in the version handshake (optional).
# mod_hash =

# How often to send heartbeat packets to the server (ms).
heartbeat_interval_ms = 1000

# How often to send the owned actor's state snapshot to the server (ms).
# Lower = smoother remote replication but more bandwidth.
snapshot_interval_ms = 16
